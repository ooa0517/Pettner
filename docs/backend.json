
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Pettner Ingredient Analyzer application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user entity."
        },
        "email": {
          "type": "string",
          "description": "Email address of the user.",
          "format": "email"
        },
        "name": {
          "type": "string",
          "description": "Full name of the user."
        },
        "isPremium": {
          "type": "boolean",
          "description": "Whether the user has purchased the lifetime unlimited pass."
        },
        "dailyUsageCount": {
          "type": "number",
          "description": "Number of analyses performed today."
        },
        "lastUsageDate": {
          "type": "string",
          "description": "The last date an analysis was performed (YYYY-MM-DD)."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user account was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "name",
        "createdAt"
      ]
    },
    "AnalysisHistory": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AnalysisHistory",
      "type": "object",
      "description": "Represents a historical record of an ingredient analysis.",
      "properties": {
        "userInput": {
          "type": "object",
          "description": "The input provided by the user for analysis."
        },
        "analysisOutput": {
          "type": "object",
          "description": "The output generated by the AI analysis."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the analysis was performed.",
          "format": "date-time"
        }
      },
      "required": [
        "userInput",
        "analysisOutput",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "google.com",
      "apple.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores user profile data and usage limits.",
          "params": [
            {
              "name": "userId",
              "description": "Firebase Auth UID."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/analysisHistory/{analysisId}",
        "definition": {
          "entityName": "AnalysisHistory",
          "schema": {
            "$ref": "#/backend/entities/AnalysisHistory"
          },
          "description": "Stores the history of analyses for a specific user.",
          "params": [
            {
              "name": "userId",
              "description": "The owner of the history."
            },
            {
              "name": "analysisId",
              "description": "The unique ID of the analysis record."
            }
          ]
        }
      }
    ]
  }
}
