
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Pettner Ingredient Analyzer application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user entity."
        },
        "email": {
          "type": "string",
          "description": "Email address of the user.",
          "format": "email"
        },
        "name": {
          "type": "string",
          "description": "Full name of the user."
        },
        "isPremium": {
          "type": "boolean",
          "description": "Whether the user has purchased the lifetime unlimited pass."
        },
        "dailyUsageCount": {
          "type": "number",
          "description": "Number of analyses performed today."
        },
        "lastUsageDate": {
          "type": "string",
          "description": "The last date an analysis was performed (YYYY-MM-DD)."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user account was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "name",
        "createdAt"
      ]
    },
    "Pet": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Pet",
      "type": "object",
      "description": "Represents a pet profile with deep medical data for nutrition analysis.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["dog", "cat"] },
        "gender": { "type": "string", "enum": ["male", "female", "unknown"] },
        "breed": { "type": "string" },
        "age": { "type": "number" },
        "weight": { "type": "number" },
        "neutered": { "type": "string", "enum": ["yes", "no", "unknown"] },
        "bcs": { "type": "string" },
        "activityLevel": { "type": "string", "enum": ["LOW", "NORMAL", "HIGH", "VERY_HIGH", "UNKNOWN"] },
        "walkingTime": { "type": "string", "description": "Average daily walking time (e.g., 'NONE', 'UNDER_30', '30_60', 'OVER_60')" },
        "livingEnvironment": { "type": "string", "enum": ["INDOOR", "OUTDOOR", "BOTH", "UNKNOWN"] },
        "weightChange": { "type": "string" },
        "healthConditions": { "type": "array", "items": { "type": "string" } },
        "allergies": { "type": "array", "items": { "type": "string" } },
        "currentDietType": { "type": "string" },
        "waterIntake": { "type": "string" },
        "stoolCondition": { "type": "string" },
        "medications": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "breed"]
    },
    "AnalysisHistory": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AnalysisHistory",
      "type": "object",
      "description": "Represents a historical record of an ingredient analysis.",
      "properties": {
        "userInput": {
          "type": "object",
          "description": "The input provided by the user for analysis."
        },
        "analysisOutput": {
          "type": "object",
          "description": "The output generated by the AI analysis."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the analysis was performed.",
          "format": "date-time"
        }
      },
      "required": [
        "userInput",
        "analysisOutput",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "google.com",
      "apple.com"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "Stores user profile data and usage limits."
    },
    "/users/{userId}/pets/{petId}": {
      "schema": { "$ref": "#/backend/entities/Pet" },
      "description": "Stores profiles of the user's pets."
    },
    "/users/{userId}/analysisHistory/{analysisId}": {
      "schema": { "$ref": "#/backend/entities/AnalysisHistory" },
      "description": "Stores the history of analyses for a specific user."
    }
  }
}
