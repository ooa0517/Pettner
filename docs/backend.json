
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user profile was created."
        }
      },
      "required": ["email", "createdAt"]
    },
    "PetProfile": {
      "title": "Pet Profile",
      "description": "Represents a pet's profile information.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The pet's name."
        },
        "petType": {
          "type": "string",
          "enum": ["Dog", "Cat"],
          "description": "The type of pet."
        },
        "breed": {
          "type": "string",
          "description": "The pet's breed."
        },
        "birthDate": {
          "type": "string",
          "format": "date",
          "description": "The pet's date of birth."
        },
        "healthConditions": {
          "type": "string",
          "description": "Any known health conditions of the pet."
        }
      },
      "required": ["name", "petType"]
    },
    "AnalysisRecord": {
      "title": "Analysis Record",
      "description": "Represents a single pet food analysis result.",
      "type": "object",
      "properties": {
        "productName": { "type": "string" },
        "brandName": { "type": "string" },
        "petType": { "type": "string" },
        "lifeStage": { "type": "string" },
        "specialClaims": { "type": "array", "items": { "type": "string" } },
        "keyTakeaways": { "type": "array", "items": { "type": "string" } },
        "summaryHeadline": { "type": "string" },
        "ingredients": { "type": "object" },
        "nutritionalAnalysis": { "type": "object" },
        "hiddenInsights": { "type": "array", "items": { "type": "string" } },
        "recommendations": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productName", "summaryHeadline", "createdAt"]
    }
  },
  "auth": {
    "providers": ["email", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores public profile information for each user, keyed by their UID."
    },
    "/users/{userId}/pets/{petId}": {
      "schema": {
        "$ref": "#/entities/PetProfile"
      },
      "description": "Stores profile information for each of a user's pets."
    },
    "/users/{userId}/analysisHistory/{analysisId}": {
      "schema": {
        "$ref": "#/entities/AnalysisRecord"
      },
      "description": "Stores the history of all analysis records for a user."
    }
  }
}
