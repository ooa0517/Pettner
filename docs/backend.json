
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user profile was created."
        }
      },
      "required": ["email", "createdAt"]
    },
    "PetProfile": {
      "title": "Pet Profile",
      "description": "Represents a pet's profile information.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The pet's name."
        },
        "petType": {
          "type": "string",
          "enum": ["Dog", "Cat"],
          "description": "The type of pet."
        },
        "breed": {
          "type": "string",
          "description": "The pet's breed."
        },
        "birthDate": {
          "type": "string",
          "format": "date",
          "description": "The pet's date of birth."
        },
        "healthConditions": {
          "type": "string",
          "description": "Any known health conditions of the pet."
        }
      },
      "required": ["name", "petType"]
    },
    "AnalysisRecord": {
      "title": "Analysis Record",
      "description": "Represents a single pet food analysis event, storing both the original user input and the AI-generated output.",
      "type": "object",
      "properties": {
        "userInput": {
          "type": "object",
          "description": "The original data submitted by the user for analysis.",
          "properties": {
            "petType": { "type": "string", "enum": ["dog", "cat"] },
            "productName": { "type": "string" },
            "brandName": { "type": "string" },
            "foodType": { "type": "string" },
            "ingredientsText": { "type": "string" },
            "healthConditions": { "type": "string" },
            "photoProvided": { "type": "boolean" },
            "lifeStage": { "type": "string" }
          },
          "required": ["petType", "productName"]
        },
        "analysisOutput": {
          "type": "object",
          "description": "The structured, user-friendly data returned from the AI analysis.",
          "properties": {
            "status": { "type": "string", "enum": ["success", "error"] },
            "productInfo": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "brand": { "type": "string" }
              }
            },
            "summary": {
              "type": "object",
              "properties": {
                "hashtags": { "type": "array", "items": { "type": "string" } },
                "safetyRating": { "type": "string", "enum": ["Green", "Yellow", "Red"] }
              }
            },
            "topIngredients": {
                "type": "array", "items": { "type": "string" }
            },
            "ingredientsAnalysis": {
              "type": "object",
              "properties": {
                "positive": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "keyword": { "type": "string" },
                      "name": { "type": "string" },
                      "description": { "type": "string" }
                    }
                  }
                },
                "caution": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "keyword": { "type": "string" },
                      "name": { "type": "string" },
                      "description": { "type": "string" }
                    }
                  }
                }
              }
            },
            "nutritionFacts": {
              "type": "object",
              "properties": {
                "comment": { "type": "string" }
              }
            },
            "expertInsight": {
              "type": "object",
              "properties": {
                "goodPoint": { "type": "string" },
                "cautionPoint": { "type": "string" },
                "proTip": { "type": "string" }
              }
            }
          },
          "required": ["status", "productInfo", "summary", "expertInsight"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the analysis was created."
        }
      },
      "required": ["userInput", "analysisOutput", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "email",
      "google.com"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores public profile information for each user, keyed by their UID."
    },
    "/users/{userId}/pets/{petId}": {
      "schema": {
        "$ref": "#/entities/PetProfile"
      },
      "description": "Stores profile information for each of a user's pets."
    },
    "/users/{userId}/analysisHistory/{analysisId}": {
      "schema": {
        "$ref": "#/entities/AnalysisRecord"
      },
      "description": "Stores the history of all analysis records for a user."
    }
  }
}
