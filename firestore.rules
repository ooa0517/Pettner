
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can create, read, and update their own profile.
    // Nobody can see the full list of users.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // A user can manage their own pets.
      match /pets/{petId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // A user can manage their own analysis history.
      match /analysisHistory/{analysisId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
